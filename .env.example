# =============================================================================
# Coder Server Configuration for Railway
# =============================================================================

# Railway will set this automatically, but you can override it with your custom domain
# CODER_ACCESS_URL=https://your-coder.up.railway.app

# Optional: Wildcard domain for port forwarding (requires custom domain)
# CODER_WILDCARD_ACCESS_URL=*.coder.yourdomain.com

# =============================================================================
# OIDC Authentication (Google Workspace example)
# Restricts access to @theagilemonkeys.com emails only
# =============================================================================
# CODER_OIDC_ISSUER_URL=https://accounts.google.com
# CODER_OIDC_CLIENT_ID=your-google-oauth-client-id
# CODER_OIDC_CLIENT_SECRET=your-google-oauth-client-secret
# CODER_OIDC_EMAIL_DOMAIN=theagilemonkeys.com
# CODER_OIDC_ALLOW_SIGNUPS=true
# CODER_OIDC_SCOPES=openid,profile,email

# Disable password auth once OIDC is configured (recommended)
# CODER_DISABLE_PASSWORD_AUTH=true

# =============================================================================
# Alternative: GitHub OAuth
# Restricts access by GitHub organization
# =============================================================================
# CODER_OAUTH2_GITHUB_CLIENT_ID=your-github-oauth-client-id
# CODER_OAUTH2_GITHUB_CLIENT_SECRET=your-github-oauth-client-secret
# CODER_OAUTH2_GITHUB_ALLOW_SIGNUPS=true
# CODER_OAUTH2_GITHUB_ALLOWED_ORGS=TheAgileMonkeys

# =============================================================================
# Database (Railway Postgres - auto-configured by setup script)
# =============================================================================
# CODER_PG_CONNECTION_URL=postgres://user:pass@host:port/dbname?sslmode=disable

# =============================================================================
# Workspace Provisioner (for remote Docker host)
# =============================================================================
# If running workspaces on a remote Docker host, the provisioner daemon
# on that host needs this token to connect back to the Coder server.
# Generate with: coder provisionerd keys create
# CODER_PROVISIONER_DAEMON_PSK=your-pre-shared-key
