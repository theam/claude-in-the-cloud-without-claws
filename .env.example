# =============================================================================
# Coder Docker Compose Configuration
# Copy this file to .env and fill in the values
# =============================================================================

# The public URL where Coder will be accessible
# For local testing: http://localhost
# For production: https://coder.yourdomain.com
CODER_ACCESS_URL=https://software.theagilemonkeys.com

# PostgreSQL credentials
POSTGRES_USER=coder
POSTGRES_PASSWORD=CHANGE_ME_TO_A_SECURE_PASSWORD
POSTGRES_DB=coder

# Docker group ID (run: getent group docker | cut -d: -f3)
DOCKER_GROUP_ID=999

# GitHub OAuth App (create at github.com/organizations/theam/settings/applications)
GITHUB_OAUTH_CLIENT_ID=your-client-id
GITHUB_OAUTH_CLIENT_SECRET=your-client-secret
